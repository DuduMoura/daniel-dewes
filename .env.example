# ─────────────────────────────────────────────────────────────
# Variáveis de ambiente — Sistema WMS
# Copie para `.env` e ajuste:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Banco de dados (PostgreSQL) — usado pelo runtime (src/lib/db.ts)
# e pelas migrations (prisma.config.ts).
#
# LOCAL (Docker — casa com os defaults do docker-compose.yml):
DATABASE_URL="postgresql://wms:wms@localhost:5432/wms"

# ─────────────────────────────────────────────────────────────
# Autenticação (src/lib/session.ts + prisma/seed.ts)
# ─────────────────────────────────────────────────────────────
# Segredo de assinatura do JWT de sessão (mín. 32 caracteres).
# Gere um com:  openssl rand -base64 32
# No Render é gerado automaticamente (generateValue no render.yaml).
SESSION_SECRET="troque-por-um-segredo-aleatorio-de-32-caracteres-ou-mais"

# Primeiro usuário GESTOR, criado pelo seed (npm run db:seed).
# Use valores reais em produção — a senha NUNCA deve ir para o repositório.
SEED_ADMIN_EMAIL="admin@exemplo.com"
SEED_ADMIN_PASSWORD="defina-uma-senha-forte"

# ─────────────────────────────────────────────────────────────
# RENDER (deploy):
#   NÃO defina DATABASE_URL à mão. O render.yaml injeta a conexão
#   automaticamente a partir do banco gerenciado (fromDatabase).
#
# VERCEL + SUPABASE (alternativa): não use DATABASE_URL; use o par:
#   POSTGRES_PRISMA_URL="postgresql://...:6543/postgres?pgbouncer=true"  # runtime (pooled)
#   POSTGRES_URL_NON_POOLING="postgresql://...:5432/postgres"           # migrations (direta)
# ─────────────────────────────────────────────────────────────
